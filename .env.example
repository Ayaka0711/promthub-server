# ---- MongoDB ----
# Get this from MongoDB Atlas: Database > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/promptHubDB?retryWrites=true&w=majority

# ---- BetterAuth ----
# Any long random string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your_long_random_secret_here

# ---- Server ----
PORT=5000
NODE_ENV=development
# Must match where THIS server actually runs (used by BetterAuth for OAuth redirects)
SERVER_URL=http://localhost:5000

# ---- Client URL (for CORS + trusted origins) ----
CLIENT_URL=http://localhost:5173

# ---- Google OAuth (for "Continue with Google") ----
# From Google Cloud Console > APIs & Services > Credentials > OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---- Stripe (for the $5 Premium unlock payment) ----
# From Stripe Dashboard > Developers > API keys (use the TEST secret key while developing)
STRIPE_SECRET_KEY=sk_test_your_key_here
